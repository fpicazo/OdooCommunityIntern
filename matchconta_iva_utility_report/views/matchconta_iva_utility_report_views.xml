<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_matchconta_iva_utility_report_wizard_form" model="ir.ui.view">
        <field name="name">matchconta.iva.utility.report.wizard.form</field>
        <field name="model">matchconta.iva.utility.report.wizard</field>
        <field name="arch" type="xml">
            <form string="IVA Utility Report">
                <header>
                    <button
                        name="action_generate_report"
                        type="object"
                        string="Generate Table"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="month"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_paid_amount" readonly="1"/>
                            <field name="total_taxable_base_16" readonly="1"/>
                            <field name="total_iva_16" readonly="1"/>
                            <field name="total_taxable_base_8" readonly="1"/>
                            <field name="total_iva_8" readonly="1"/>
                            <field name="total_exempt_amount" readonly="1"/>
                            <field name="total_other_taxable_base" readonly="1"/>
                            <field name="total_other_iva" readonly="1"/>
                            <field name="total_iva_amount" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0">
                            <field name="partner_id"/>
                            <field name="third_party_type"/>
                            <field name="operation_type"/>
                            <field name="rfc"/>
                            <field name="country_code"/>
                            <field name="document_names" optional="show"/>
                            <field name="payment_references" optional="hide"/>
                            <field name="paid_amount" sum="Total"/>
                            <field name="taxable_base_16" sum="Total"/>
                            <field name="iva_16" sum="Total"/>
                            <field name="taxable_base_8" sum="Total"/>
                            <field name="iva_8" sum="Total"/>
                            <field name="exempt_amount" sum="Total"/>
                            <field name="other_taxable_base" sum="Total"/>
                            <field name="other_iva" sum="Total"/>
                            <field name="total_iva" sum="Total"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_matchconta_iva_utility_report" model="ir.actions.act_window">
        <field name="name">IVA Utility Report</field>
        <field name="res_model">matchconta.iva.utility.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_matchconta_root" name="MatchConta" sequence="10"/>
    <menuitem
        id="menu_matchconta_iva_utility_report"
        name="IVA Utility Report"
        parent="menu_matchconta_root"
        action="action_matchconta_iva_utility_report"
        sequence="10"
    />
</odoo>
