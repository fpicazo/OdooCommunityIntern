<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_matchconta_iva_utility_report_wizard_form" model="ir.ui.view">
        <field name="name">matchconta.iva.utility.report.wizard.form</field>
        <field name="model">matchconta.iva.utility.report.wizard</field>
        <field name="arch" type="xml">
            <form string="IVA Utility Report">
                <header>
                    <button
                        name="action_generate_report"
                        type="object"
                        string="Generate Report"
                        class="btn-primary"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="month"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_customer_payment" readonly="1"/>
                            <field name="total_customer_iva" readonly="1"/>
                            <field name="total_supplier_payment" readonly="1"/>
                            <field name="total_supplier_iva" readonly="1"/>
                            <field name="period_iva_no_acreditable" readonly="1"/>
                            <field name="period_depreciation" readonly="1"/>
                            <field name="total_iva_difference" readonly="1"/>
                            <field name="total_utility" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0">
                            <field name="date"/>
                            <field name="payment_id" optional="show"/>
                            <field name="partner_id" optional="show"/>
                            <field name="payment_reference"/>
                            <field name="invoice_names" optional="show"/>
                            <field name="customer_payment" sum="Total"/>
                            <field name="customer_iva" sum="Total"/>
                            <field name="supplier_payment" sum="Total"/>
                            <field name="supplier_iva" sum="Total"/>
                            <field name="iva_no_acreditable" sum="Total"/>
                            <field name="payroll_amount" sum="Total"/>
                            <field name="depreciation_amount" sum="Total"/>
                            <field name="iva_difference" sum="Total"/>
                            <field name="utility" sum="Total"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_matchconta_iva_utility_report_line_list" model="ir.ui.view">
        <field name="name">matchconta.iva.utility.report.line.list</field>
        <field name="model">matchconta.iva.utility.report.line</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" edit="0">
                <field name="date"/>
                <field name="transaction_type"/>
                <field name="partner_id"/>
                <field name="payment_reference" optional="show"/>
                <field name="invoice_names" optional="show"/>
                <field name="customer_payment" sum="Total"/>
                <field name="customer_iva" sum="Total"/>
                <field name="supplier_payment" sum="Total"/>
                <field name="supplier_iva" sum="Total"/>
                <field name="iva_no_acreditable" sum="Total"/>
                <field name="payroll_amount" sum="Total"/>
                <field name="depreciation_amount" sum="Total"/>
                <field name="iva_difference" sum="Total"/>
                <field name="utility" sum="Total"/>
                <field name="declared_ingreso" optional="show"/>
                <field name="declared_egreso" optional="show"/>
                <field name="declared_isr" optional="show"/>
                <field name="declared_iva_cobrado" optional="show"/>
                <field name="declared_iva_pagado" optional="show"/>
                <field name="declared_iva_pagable" optional="show"/>
                <field name="declared_nomina" optional="show"/>
                <field name="declared_isr_nomina_pagado" optional="show"/>
                <field name="declared_perdidas_fiscales_aplicadas_periodo" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_matchconta_iva_utility_report_line_search" model="ir.ui.view">
        <field name="name">matchconta.iva.utility.report.line.search</field>
        <field name="model">matchconta.iva.utility.report.line</field>
        <field name="arch" type="xml">
            <search string="IVA Utility Report">
                <field name="partner_id"/>
                <field name="payment_id"/>
                <field name="payment_reference"/>
                <field name="invoice_names"/>
                <field name="report_company_id"/>
                <field name="report_month"/>
                <field name="report_year"/>
                <field name="transaction_type"/>
                <filter name="with_customer" string="With Customer" domain="[('customer_payment', '!=', 0)]"/>
                <filter name="with_supplier" string="With Supplier" domain="[('supplier_payment', '!=', 0)]"/>
                <filter name="current_year" string="Current Year" domain="[('report_year', '=', context_today().year)]"/>
                <separator/>
                <filter name="group_by_transaction_type" string="Type" context="{'group_by': 'transaction_type'}"/>
                <filter name="group_by_payment_month" string="Month" context="{'group_by': 'date:month'}"/>
                <filter name="group_by_partner" string="Partner" context="{'group_by': 'partner_id'}"/>
                <filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
                <filter name="group_by_company" string="Company" context="{'group_by': 'report_company_id'}"/>
                <filter name="group_by_report_month" string="Selected Month" context="{'group_by': 'report_month'}"/>
            </search>
        </field>
    </record>

    <record id="view_matchconta_iva_utility_report_line_form" model="ir.ui.view">
        <field name="name">matchconta.iva.utility.report.line.form</field>
        <field name="model">matchconta.iva.utility.report.line</field>
        <field name="arch" type="xml">
            <form string="IVA Utility Report Line" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="transaction_type" string="Type"/>
                            <field name="payment_id"/>
                            <field name="partner_id"/>
                            <field name="payment_reference"/>
                            <field name="invoice_names"/>
                        </group>
                        <group>
                            <field name="report_company_id"/>
                            <field name="report_period_label" string="Period"/>
                            <field name="customer_payment"/>
                            <field name="customer_iva"/>
                            <field name="supplier_payment"/>
                            <field name="supplier_iva"/>
                            <field name="iva_difference"/>
                            <field name="utility"/>
                            <field name="declared_ingreso"/>
                            <field name="declared_egreso"/>
                            <field name="declared_isr"/>
                            <field name="declared_iva_cobrado"/>
                            <field name="declared_iva_pagado"/>
                            <field name="declared_iva_pagable"/>
                            <field name="iva_no_acreditable"/>
                            <field name="payroll_amount"/>
                            <field name="depreciation_amount"/>
                            <field name="declared_nomina"/>
                            <field name="declared_isr_nomina_pagado"/>
                            <field name="declared_perdidas_fiscales_aplicadas_periodo"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_matchconta_iva_utility_report_debug_form" model="ir.ui.view">
        <field name="name">matchconta.iva.utility.report.debug.form</field>
        <field name="model">matchconta.iva.utility.report.debug</field>
        <field name="arch" type="xml">
            <form string="IVA Utility Report Debug" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="message" nolabel="1" widget="text"/>
                    </group>
                    <footer>
                        <button string="Close" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_matchconta_iva_utility_report_server" model="ir.actions.server">
        <field name="name">IVA Utility Report</field>
        <field name="model_id" ref="model_matchconta_iva_utility_report_wizard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_current_report()</field>
    </record>

    <record id="action_matchconta_iva_utility_report_wizard" model="ir.actions.act_window">
        <field name="name">Generate IVA Utility Report</field>
        <field name="res_model">matchconta.iva.utility.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <record id="action_matchconta_iva_utility_report_lines" model="ir.actions.act_window">
        <field name="name">IVA Utility Reports</field>
        <field name="res_model">matchconta.iva.utility.report.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_matchconta_iva_utility_report_line_search"/>
        <field name="context">{"search_default_group_by_payment_month": 1}</field>
    </record>

    <menuitem id="menu_matchconta_root" name="MatchConta" sequence="10"/>
    <menuitem
        id="menu_matchconta_iva_utility_report"
        name="IVA Utility Report"
        parent="menu_matchconta_root"
        action="action_matchconta_iva_utility_report_lines"
        sequence="10"
    />
    <menuitem
        id="menu_matchconta_iva_utility_report_generate"
        name="Generate Report"
        parent="menu_matchconta_root"
        action="action_matchconta_iva_utility_report_wizard"
        sequence="20"
    />

    <!-- Declared Amounts Views -->
    <record id="view_matchconta_declared_amounts_form" model="ir.ui.view">
        <field name="name">matchconta.declared.amounts.form</field>
        <field name="model">matchconta.declared.amounts</field>
        <field name="arch" type="xml">
            <form string="Declared Amounts">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="month" nolabel="1" class="oe_inline"/>
                            <span class="mx-2"/>
                            <field name="year" nolabel="1" class="oe_inline"/>
                        </h1>
                    </div>
                    <group col="4">
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group col="4" string="Income and Expenses">
                        <field name="ingreso_declarado"/>
                        <field name="egreso_declarado"/>
                    </group>
                    <group col="4" string="ISR (Income Tax)">
                        <field name="isr_declarado"/>
                        <field name="isr_nomina_pagado"/>
                        <field name="perdidas_fiscales_aplicadas_periodo"/>
                    </group>
                    <group col="4" string="IVA (Value Added Tax)">
                        <field name="iva_cobrado_declarado"/>
                        <field name="iva_pagado"/>
                        <field name="iva_pagable_declarado"/>
                        <field name="iva_no_acreditable" readonly="1"/>
                    </group>
                    <group col="4" string="Payroll">
                        <field name="nomina_declarado"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_matchconta_declared_amounts_list" model="ir.ui.view">
        <field name="name">matchconta.declared.amounts.list</field>
        <field name="model">matchconta.declared.amounts</field>
        <field name="arch" type="xml">
            <list string="Declared Amounts">
                <field name="company_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="ingreso_declarado" sum="Total"/>
                <field name="egreso_declarado" sum="Total"/>
                <field name="isr_declarado" sum="Total"/>
                <field name="iva_cobrado_declarado" sum="Total"/>
                <field name="iva_pagado" sum="Total"/>
                <field name="iva_pagable_declarado" sum="Total"/>
                <field name="iva_no_acreditable" sum="Total"/>
                <field name="nomina_declarado" sum="Total"/>
                <field name="isr_nomina_pagado" sum="Total"/>
                <field name="perdidas_fiscales_aplicadas_periodo" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="view_matchconta_declared_amounts_search" model="ir.ui.view">
        <field name="name">matchconta.declared.amounts.search</field>
        <field name="model">matchconta.declared.amounts</field>
        <field name="arch" type="xml">
            <search string="Declared Amounts">
                <field name="company_id"/>
                <field name="month"/>
                <field name="year"/>
                <separator/>
                <filter name="current_year" string="Current Year" domain="[('year', '=', context_today().year)]"/>
                <separator/>
                <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                <filter name="group_by_year" string="Year" context="{'group_by': 'year'}"/>
                <filter name="group_by_month" string="Month" context="{'group_by': 'month'}"/>
            </search>
        </field>
    </record>

    <record id="action_matchconta_declared_amounts" model="ir.actions.act_window">
        <field name="name">Declared Amounts</field>
        <field name="res_model">matchconta.declared.amounts</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_current_year": 1}</field>
    </record>

    <menuitem
        id="menu_matchconta_declared_amounts"
        name="Declared Amounts"
        parent="menu_matchconta_root"
        action="action_matchconta_declared_amounts"
        sequence="30"
    />
</odoo>
