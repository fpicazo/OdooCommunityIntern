<odoo>
    <record id="view_move_form_invoice_payment_exchange_sync" model="ir.ui.view">
        <field name="name">account.move.form.invoice.payment.exchange.sync</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_sync_existing_payments_exchange_rate"
                        type="object"
                        string="Convert Existing Payments to MXN"
                        class="oe_highlight"
                        invisible="state != 'posted' or payment_state == 'not_paid'"/>
            </xpath>
        </field>
    </record>
</odoo>
